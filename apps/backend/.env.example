# Build endpoint security
AEPRA_BUILD_API_TOKEN=replace_with_strong_random_token
AEPRA_BUILD_RATE_LIMIT_WINDOW_SECONDS=60
AEPRA_BUILD_RATE_LIMIT_MAX_REQUESTS=12
AEPRA_BUILD_MAX_BLUEPRINT_BYTES=500000

# Allowed browser origins (comma separated)
AEPRA_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Trusted hosts for FastAPI/Starlette (comma separated)
AEPRA_TRUSTED_HOSTS=localhost,127.0.0.1
